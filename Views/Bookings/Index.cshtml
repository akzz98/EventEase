@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Booking Management";
}

<h2 class="mb-4">Booking Management</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Create New Booking</a>

    <!-- PART 2: SEARCH BAR -->
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by Booking ID or Event Name..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No bookings found matching your search.</div>
}
else
{
    <table class="table table-striped table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Venue Name</th>
                <th>Venue Location</th>
                <th>Event Name</th>
                <th>Start Date & Time</th>
                <th>End Date & Time</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BookingId</td>
                    <td>@item.Venue?.Name</td>
                    <td>@item.Venue?.Location</td>
                    <td>@item.Event?.Name</td>
                    <td>@item.StartDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.EndDateTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        <span class="badge @(item.Status == "Confirmed" ? "bg-success" : "bg-secondary")">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}